<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORBE C Films</title>

    <!-- Slick Carousel -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>

    <style>
        body {
            margin: 0;
            background-color: #000;
            color: #fff;
            font-family: 'Courier New', Courier, monospace;
        }

        h1, h2, .servicio-texto, footer p {
            font-family: 'Bebas Neue', sans-serif;
        }

        /* PRELOADER */
        #preloader {
            position: fixed;
            inset: 0;
            background: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }

        #loader-content img {
            width: 150px;
            height: auto;
        }

        @keyframes powerOn {
            0% {
                opacity: 0;
                filter: brightness(0.2) blur(4px);
                transform: scale(0.9);
            }
            40% {
                opacity: 1;
                filter: brightness(1.5) blur(2px);
            }
            70% {
                filter: brightness(0.9);
            }
            100% {
                opacity: 1;
                filter: brightness(1);
                transform: scale(1);
            }
        }

        .power-on {
            animation: powerOn 2.5s ease-out forwards;
        }

        /* HEADER */
        header {
            background: #000;
            padding: 20px;
            text-align: center;
        }

        header img {
            width: 100px;
        }

        header a {
            color: #fff;
            margin: 0 15px;
            text-decoration: none;
        }

        /* SECTIONS */
        #nuestros-proyectos,
        #nuestros-servicios {
            text-align: center;
            margin: 40px 0 20px;
        }

        #carrete {
            width: 80%;
            margin: auto;
        }

        iframe {
            width: 100%;
            height: 400px;
        }

        #carrete-servicios img {
            width: 100%;
            border-radius: 8px;
        }

        .servicio-texto {
            position: absolute;
            inset: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 40px;
            text-shadow: 2px 2px 4px #000;
        }

        .slick-slide {
            position: relative;
        }

        #redes-sociales,
        footer {
            background: #333;
            text-align: center;
            padding: 20px;
        }

        #contacto {
            text-align: center;
            padding: 40px 20px;
        }
    </style>
</head>

<body>

<!-- PRELOADER -->
<div id="preloader">
    <div id="loader-content">
        <img src="imagenes/logo.png" alt="Cargando" class="power-on">
    </div>
</div>

<header>
    <img src="imagenes/logo.png" alt="ORBE C Films">
    <h1>ORBE C Films</h1>
    <a href="quienes-somos.html">Quiénes somos</a>
    <a href="OrbeCBlog.html">Orbe-C Blog</a>
</header>

<section id="nuestros-proyectos">
    <h2>Nuestros Proyectos</h2>
</section>

<div id="carrete">
    <div><iframe src="https://www.youtube.com/embed/2Pa6RBmFt90" allowfullscreen></iframe></div>
    <div><iframe src="https://www.youtube.com/embed/UVAwpWqnXYo" allowfullscreen></iframe></div>
    <div><iframe src="https://www.youtube.com/embed/p9cOB6H7UZQ" allowfullscreen></iframe></div>
    <div><iframe src="https://www.youtube.com/embed/ykCLdz4IZvY" allowfullscreen></iframe></div>
    <div><iframe src="https://www.youtube.com/embed/i1g7NzY2TbE" allowfullscreen></iframe></div>
</div>

<section id="nuestros-servicios">
    <h2>Nuestros Servicios</h2>
</section>

<div id="carrete-servicios">
    <div>
        <img src="imagenes/EdicionCap.jpg">
        <div class="servicio-texto">Edición de video</div>
    </div>
    <div>
        <img src="imagenes/rs.jpg">
        <div class="servicio-texto">Contenido para redes</div>
    </div>
    <div>
        <img src="imagenes/FtProducto.jpg">
        <div class="servicio-texto">Fotografía de producto</div>
    </div>
</div>

<div id="redes-sociales">
    <a href="https://www.instagram.com/ronilio_" target="_blank">Instagram</a>
</div>

<section id="contacto">
    <p>HAGAMOS REALIDAD TUS HISTORIAS</p>
    <p>Email: rtiz.ronny@gmail.com</p>
    <p>Tel: 7029-5222</p>
</section>

<footer>
    <p>© 2026 ORBE C Films</p>
</footer>

<script>
    window.addEventListener('load', () => {
        const preloader = document.getElementById('preloader');
        preloader.style.opacity = '0';
        setTimeout(() => preloader.style.display = 'none', 500);
    });

    $(document).ready(function(){
        $('#carrete, #carrete-servicios').slick({
            autoplay: true,
            autoplaySpeed: 5000,
            dots: true,
            arrows: false
        });
    });
</script>

</body>
</html>
