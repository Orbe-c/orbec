    <!-- Estilo CSS -->
    <style>
        /* tipografía Bebas Neue */
        body,
        #nuestros-proyectos h2,
        #nuestros-servicios h2,
        .servicio-texto,
        footer p {
            font-family: 'Bebas Neue', sans-serif;
        }

        body {
            background-color: #000; /* Negro */
            color: #ffffff; /* Blanco */
            font-family: 'Courier New', Courier, monospace;
            margin: 0;
            padding: 0;
        }

        /* PRELOADER con animación mejorada */
        #preloader {
            position: fixed;
            width: 100%;
            height: 100%;
            background-color: #000;
            top: 0;
            left: 0;
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 1;
            transition: opacity 0.5s ease;
        }

        #preloader.fade-out {
            opacity: 0;
        }

        #loader-content {
            text-align: center;
        }

        #loader-content img {
            width: 150px;
            height: auto;
        }

        /* Animación estilo "encendido de TV" */
        @keyframes powerOn {
            0% {
                opacity: 0;
                filter: brightness(0.2) blur(4px);
                transform: scale(0.9);
            }
            40% {
                opacity: 1;
                filter: brightness(1.5) blur(2px);
            }
            70% {
                filter: brightness(0.9);
            }
            100% {
                opacity: 1;
                filter: brightness(1);
                transform: scale(1);
            }
        }

        .power-on {
            animation: powerOn 2.5s ease-out forwards;
        }
        /* Termina pre Loader*/

        /* Header */
        header {
            background-color: #000;
            padding: 20px;
            text-align: center;
        }

        #logo-container img {
            width: 100px;
            height: auto;
        }

        header h1 {
            margin: 10px 0;
            font-size: 1.5em;
        }

        header a {
            color: #ffffff;
            margin: 0 20px;
            font-size: 18px;
            text-decoration: none;
            font-family: 'Courier New', Courier, monospace;
            transition: opacity 0.3s ease;
        }

        header a:hover {
            opacity: 0.7;
        }

        /* Secciones */
        #nuestros-proyectos,
        #nuestros-servicios {
            text-align: center;
            margin-top: 20px;
            font-size: 24px;
            color: #ffffff;
        }

        /* Carrusel de videos */
        #carrete {
            width: 80%;
            margin: 0 auto;
            position: relative;
        }

        .slick-slide {
            text-align: center;
            color: #999;
        }

        .slick-slide iframe {
            width: 100%;
            height: 400px;
        }

        /* Carrusel de servicios */
        #carrete-servicios {
            width: 100%;
            margin: 0;
            text-align: center;
            overflow: hidden;
            position: relative;
        }

        #carrete-servicios .slick-slide {
            position: relative;
        }

        #carrete-servicios img {
            width: 100%;
            height: auto;
            border-radius: 8px;
            display: block;
        }

        .servicio-texto {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ffffff;
            font-size: 40px;
            font-weight: bold;
            text-align: center;
            width: 80%;
            z-index: 1;
            text-shadow: 2px 2px 4px #000;
        }

        /* Flechas del carrusel */
        .carousel-prev,
        .carousel-next {
            font-size: 30px;
            color: #fff;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            z-index: 2;
            background: rgba(0, 0, 0, 0.5);
            padding: 10px 15px;
            border-radius: 5px;
            user-select: none;
        }

        .carousel-prev:hover,
        .carousel-next:hover {
            background: rgba(0, 0, 0, 0.8);
        }

        .carousel-prev {
            left: 10px;
        }

        .carousel-next {
            right: 10px;
        }

        /* Redes sociales */
        #redes-sociales {
            background-color: #333333;
            padding: 20px;
            text-align: center;
            color: #fff;
        }

        #redes-sociales a {
            color: #fff;
            margin: 0 10px;
            font-size: 20px;
            text-decoration: none;
            transition: opacity 0.3s ease;
        }

        #redes-sociales a:hover {
            opacity: 0.7;
        }

        /* Contacto */
        #contacto {
            background-color: #000000;
            padding: 40px 20px;
            text-align: center;
            color: #fff;
        }

        #contacto h2 {
            margin: 20px 0;
        }

        #contacto p {
            margin: 10px 0;
        }

        /* Footer */
        footer {
            background-color: #333333;
            padding: 20px;
            text-align: center;
        }

        /* Responsive */
        @media (max-width: 768px) {
            header h1 {
                font-size: 1.2em;
            }

            header a {
                display: block;
                margin: 10px 0;
            }

            #carrete {
                width: 95%;
            }

            .slick-slide iframe {
                height: 250px;
            }

            .servicio-texto {
                font-size: 28px;
            }
        }
    </style>
</head>

